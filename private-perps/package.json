{
  "name": "arclend-monorepo",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build:program": "anchor build",
    "test:program": "anchor test",
    "arcium:init": "arcium init",
    "arcium:build": "arcium build",
    "arcium:deploy": "arcium deploy --cluster-offset 456 --recovery-set-size 4 --keypair-path ~/.config/solana/id.json --rpc-url $HELIUS_DEVNET_RPC_URL",
    "dev": "npm run dev -w arclend-app",
    "build": "npm run build -w arclend-app"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.2",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "chai": "^5.1.2",
    "ts-mocha": "^10.1.0",
    "typescript": "^5.6.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}